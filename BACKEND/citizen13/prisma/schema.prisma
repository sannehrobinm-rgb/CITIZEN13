generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model quiz_forms {
  id                   Int       @id @default(autoincrement())
  nom_benevole         String?   @db.VarChar(100)
  adresse              String?   @db.VarChar(200)
  quartier             String?   @db.VarChar(100)
  batiment             Boolean?
  immeuble             Boolean?
  maison               Boolean?
  batiment_numero      String?   @db.VarChar(20)
  etage                String?   @db.VarChar(10)
  appartement          String?   @db.VarChar(10)
  inscrit_listes       String?   @db.VarChar(50)
  intention_vote       String?   @db.VarChar(50)
  aide_procuration     Boolean?
  raisons_non_vote     String[]
  raison_autre_texte   String?
  info_municipales     String?   @db.VarChar(50)
  interets             String[]
  preoccupations_texte String?
  themes_importants    String[]
  propositions_texte   String?
  souhait_suivi        String[]
  contact_accord       Boolean?
  nom                  String?   @db.VarChar(50)
  prenom               String?   @db.VarChar(50)
  telephone            String?   @db.VarChar(20)
  email                String?   @db.VarChar(100)
  soutien_assoc        String?   @db.VarChar(50)
  souhait_don          Boolean?
  date_visite          String?   @db.VarChar(20)
  heure_visite         String?   @db.VarChar(20)
  archived             Boolean?  @default(false)
  created_at           DateTime? @default(now()) @db.Timestamp(6)
  visite               visites?
  audio                audio?
}

model agents {
  id           Int           @id @default(autoincrement())
  nom          String        @db.VarChar(100)
  prenom       String?       @db.VarChar(100)
  email        String?       @unique @db.VarChar(100)
  password     String?       @db.VarChar(255)
  telephone    String?       @db.VarChar(20)
  role         String        @default("benevole") @db.VarChar(50)
  zone         String?       @db.VarChar(100)
  actif        Boolean       @default(true)
  created_at   DateTime      @default(now())
  visites      visites[]
  dons         dons[]
  accounts     accounts[]
  sessions     sessions[]
  boitages     boitage[]
  prospections prospection[]
  tractages    tractage[]
  reunions     reunion[]
  reset_token         String?  @db.VarChar(255)
reset_token_expires DateTime?
}

model visites {
  id           Int        @id @default(autoincrement())
  agent_id     Int
  form_id      Int        @unique
  date_visite  String?    @db.VarChar(20)
  heure_visite String?    @db.VarChar(20)
  quartier     String?    @db.VarChar(100)
  adresse      String?    @db.VarChar(200)
  notes        String?
  created_at   DateTime   @default(now())
  agent        agents     @relation(fields: [agent_id], references: [id])
  form         quiz_forms @relation(fields: [form_id], references: [id])
}

model audio {
  id            Int        @id @default(autoincrement())
  form_id       Int        @unique
  fichier_url   String?    @db.VarChar(500)
  transcription String?
  mots_cles     String[]
  duree_sec     Int?
  created_at    DateTime   @default(now())
  form          quiz_forms @relation(fields: [form_id], references: [id])
}

model dons {
  id         Int      @id @default(autoincrement())
  agent_id   Int?
  montant    Float?
  statut     String   @default("en_attente") @db.VarChar(50)
  type       String   @default("don") @db.VarChar(50)
  nom        String?  @db.VarChar(100)
  email      String?  @db.VarChar(100)
  notes      String?
  created_at DateTime @default(now())
  agent      agents?  @relation(fields: [agent_id], references: [id])
}

model boitage {
  id           Int      @id @default(autoincrement())
  agent_id     Int?
  nom_benevole String?  @db.VarChar(100)
  date         String   @db.VarChar(20)
  quartier     String   @db.VarChar(100)
  adresse      String?  @db.VarChar(200)
  nb_tracts    Int      @default(0)
  nb_boites    Int      @default(0)
  commentaire  String?
  created_at   DateTime @default(now())
  agent        agents?  @relation(fields: [agent_id], references: [id])
}

model prospection {
  id           Int      @id @default(autoincrement())
  agent_id     Int?
  nom_benevole String?  @db.VarChar(100)
  date         String   @db.VarChar(20)
  quartier     String   @db.VarChar(100)
  adresse      String?  @db.VarChar(200)
  nb_tracts    Int      @default(0)
  nb_portes    Int      @default(0)
  commentaire  String?
  rapport      String?
  created_at   DateTime @default(now())
  agent        agents?  @relation(fields: [agent_id], references: [id])
}

model tractage {
  id           Int      @id @default(autoincrement())
  agent_id     Int?
  nom_benevole String?  @db.VarChar(100)
  date         String   @db.VarChar(20)
  quartier     String   @db.VarChar(100)
  adresse      String?  @db.VarChar(200)
  nb_tracts    Int      @default(0)
  nb_portes    Int      @default(0)
  commentaire  String?
  rapport      String?
  created_at   DateTime @default(now())
  agent        agents?  @relation(fields: [agent_id], references: [id])
}

model reunion {
  id            Int      @id @default(autoincrement())
  titre         String   @db.VarChar(200)
  date          String   @db.VarChar(20)
  lieu          String?  @db.VarChar(200)
  ordre_du_jour String?
  participants  String?
  transcription String?
  rapport       String?
  fichier_url   String?  @db.VarChar(500)
  agent_nom     String?  @db.VarChar(100)
  agent_id      Int?
  created_at    DateTime @default(now())
  agent         agents?  @relation(fields: [agent_id], references: [id])
}

model accounts {
  id                String  @id @default(cuid())
  agent_id          Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  agent             agents  @relation(fields: [agent_id], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model sessions {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  agent_id     Int
  expires      DateTime
  agent        agents   @relation(fields: [agent_id], references: [id], onDelete: Cascade)
}

model evenements {
 id            Int      @id @default(autoincrement())
  titre         String   @db.VarChar(200)
  date          String   @db.VarChar(20)       
  heure      String?
  adresse    String?  @db.VarChar(200)
  sujets     String?
  photo_url  String?
  created_at    DateTime @default(now())
  updated_at DateTime @updatedAt
}

model form_templates {
  id         Int      @id @default(autoincrement())
  title      String   @db.VarChar(200)
  questions  String[]
  isActive   Boolean  @default(true)
  archived   Boolean  @default(false)
  rib        String?  @db.VarChar(200)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}